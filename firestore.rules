rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isPairMember(pairId) {
      let pair = get(/databases/$(database)/documents/pairs/$(pairId));
      return request.auth != null &&
        (pair.data.user1Id == request.auth.uid ||
         pair.data.user2Id == request.auth.uid);
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /pairs/{pairId} {
      allow create: if request.auth != null &&
        request.resource.data.user1Id == request.auth.uid &&
        request.resource.data.user2Id == null &&
        request.resource.data.keys().hasOnly(['user1Id', 'user2Id', 'pairCode', 'createdAt']);

      allow read: if request.auth != null &&
        (resource.data.user1Id == request.auth.uid ||
         resource.data.user2Id == request.auth.uid ||
         resource.data.user2Id == null);

      allow update: if request.auth != null &&
        (
          resource.data.user1Id == request.auth.uid ||
          resource.data.user2Id == request.auth.uid ||
          (
            resource.data.user2Id == null &&
            request.resource.data.user1Id == resource.data.user1Id &&
            request.resource.data.user2Id == request.auth.uid &&
            request.resource.data.pairCode == resource.data.pairCode &&
            request.resource.data.createdAt == resource.data.createdAt &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['user2Id'])
          )
        );

      allow delete: if request.auth != null &&
        (resource.data.user1Id == request.auth.uid ||
         resource.data.user2Id == request.auth.uid);

      match /{document=**} {
        allow read, write: if isPairMember(pairId);
      }
    }
  }
}
